import React, { useState, useEffect, useMemo } from "react";

// ── Persistent storage ──────────────────────────────────────────────────────
const STORE_KEY = "lea-journal-v5";
function loadData() {
  try { const raw = localStorage.getItem(STORE_KEY); return raw ? JSON.parse(raw) : null; }
  catch { return null; }
}
function saveData(d) {
  try { localStorage.setItem(STORE_KEY, JSON.stringify(d)); } catch {}
}

// ── Constants ───────────────────────────────────────────────────────────────
const SETUPS = ["Breakout","Pullback","Reversal","Trend Follow","Range","Gap Fill","News Catalyst","VWAP Reclaim","Support/Resistance","Other"];
const SESSIONS = ["Pre-Market","London Open","NY Open","Midday","NY Close","After Hours"];
const TIMEFRAMES = ["Scalp","1m","5m","15m","30m","1H","4H","Daily","Swing"];
const EMO = ["Confident","Disciplined","Neutral","Anxious","Excited","FOMO","Restless","Calm","Greedy","Fearful","Frustrated","Tilt"];
const MISTAKES = ["Revenge Trade","FOMO Entry","Chased Move","Moved SL","No SL","Oversize","Boredom","Broke Rules","Early Exit","Late Entry","Greed Hold","Tilt"];
const LESSONS = ["Good Entry","Good Exit","Patience","Followed Plan","Good Risk Mgmt","Correct Analysis","Quality Setup"];
const DEF_RULES = [
  {id:"r1",text:"Max 2 trades per day",sev:"hard",on:true},
  {id:"r2",text:"Stop after 2 consecutive losses",sev:"hard",on:true},
  {id:"r3",text:"Minimum 1:2 risk-to-reward",sev:"hard",on:true},
  {id:"r4",text:"Stop loss required before entry",sev:"hard",on:true},
  {id:"r5",text:"A+ setups only",sev:"warn",on:true},
  {id:"r6",text:"No trades during high-impact news",sev:"warn",on:true},
];
const EMPTY_TRADE = {
  id:null, date:new Date().toISOString().slice(0,10),
  asset:"", direction:"Long", session:"NY Open", setup:"", timeframe:"1H",
  entry:"", stopLoss:"", takeProfit:"", riskPct:"", actualR:"", pnlMoney:"",
  entryTime:"", exitTime:"", whyTrade:"", matchedPlan:"Matched Plan",
  emotionBefore:"Neutral", emotionAfter:"Neutral",
  mistakeTags:[], lessonTags:[], rulesFollowed:[], notes:""
};

// ── Helpers ─────────────────────────────────────────────────────────────────
const fmtPnl = v => { if(!v && v!==0) return "—"; const n=parseFloat(v); return (n>=0?"+":"")+`$${Math.abs(n).toLocaleString("en-US",{minimumFractionDigits:2,maximumFractionDigits:2})}`; };
const fmtR = v => v ? `${parseFloat(v)>0?"+":""}${parseFloat(v).toFixed(2)}R` : "—";
const pnlClr = v => !v&&v!==0 ? "#666" : parseFloat(v)>0 ? "#22c55e" : parseFloat(v)<0 ? "#ef4444" : "#666";
const clamp = (v,a,b) => Math.min(b,Math.max(a,v));

// ── Discipline score ─────────────────────────────────────────────────────────
function calcScore(t, rules) {
  let s = 0;
  if(t.matchedPlan==="Matched Plan") s+=25; else if(t.matchedPlan==="Partial Plan") s+=12;
  if(t.stopLoss && parseFloat(t.stopLoss)>0) s+=15;
  if(t.riskPct && parseFloat(t.riskPct)<=2) s+=20;
  if(t.setup && (t.whyTrade||"").length>20) s+=10;
  if(!t.mistakeTags?.includes("Revenge Trade") && !t.mistakeTags?.includes("Tilt")) s+=10;
  const activeRules = rules.filter(r=>r.on);
  if(activeRules.length && (t.rulesFollowed||[]).length >= activeRules.length) s+=10;
  if((t.notes||"").length>10) s+=10;
  return clamp(Math.round(s),0,100);
}
function scoreGrade(s) {
  if(s>=90) return {label:"Elite",color:"#22c55e"};
  if(s>=75) return {label:"Strong",color:"#86efac"};
  if(s>=60) return {label:"Average",color:"#D4A843"};
  if(s>=40) return {label:"Weak",color:"#f97316"};
  return {label:"High Risk",color:"#ef4444"};
}

// ── Mini sparkline ───────────────────────────────────────────────────────────
function Spark({ data, w=200, h=48 }) {
  if(!data||data.length<2) return <div style={{height:h,color:"#444",fontSize:11,display:"flex",alignItems:"center",paddingLeft:4}}>No data yet</div>;
  const mn=Math.min(...data,0), mx=Math.max(...data,0), rng=mx-mn||1;
  const pts=data.map((v,i)=>({ x:(i/(data.length-1))*w, y:h-((v-mn)/rng)*h }));
  const last=data[data.length-1]||0;
  const col=last>=0?"#22c55e":"#ef4444";
  const zy=h-((0-mn)/rng)*h;
  const polyPts=pts.map(p=>`${p.x},${p.y}`).join(" ");
  const areaPts=`0,${h} ${polyPts} ${w},${h}`;
  return (
    <svg width={w} height={h} viewBox={`0 0 ${w} ${h}`} style={{display:"block"}}>
      <defs>
        <linearGradient id="spkGrad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={col} stopOpacity="0.25"/>
          <stop offset="100%" stopColor={col} stopOpacity="0"/>
        </linearGradient>
      </defs>
      <polygon points={areaPts} fill="url(#spkGrad)"/>
      <polyline fill="none" stroke={col} strokeWidth="1.8" points={polyPts} strokeLinejoin="round"/>
      <line x1="0" y1={zy} x2={w} y2={zy} stroke="#333" strokeDasharray="3,3" strokeWidth="1"/>
      <circle cx={pts[pts.length-1].x} cy={pts[pts.length-1].y} r="3" fill={col}/>
    </svg>
  );
}

// ── Design tokens ────────────────────────────────────────────────────────────
const GOLD="#D4A843"; const GOLD2="#F0C060";
const BG="#0A0A0A"; const CARD="#111"; const CARD2="#161616";
const BRD="#222"; const BRD2="#2a2a2a";
const TEXT="#F0ECE0"; const MUT="#6B6555"; const MUT2="#3A3428";

// ── Reusable components ──────────────────────────────────────────────────────
function Inp({label, type="text", value, onChange, placeholder, step}) {
  const [foc,setFoc]=useState(false);
  return (
    <div style={{display:"flex",flexDirection:"column",gap:5}}>
      {label && <label style={{fontSize:11,color:MUT,textTransform:"uppercase",letterSpacing:"0.09em",fontWeight:500}}>{label}</label>}
      <input type={type} value={value} onChange={onChange} placeholder={placeholder} step={step}
        style={{background:"#0d0d0d",border:`1px solid ${foc?GOLD:BRD2}`,borderRadius:8,padding:"9px 12px",color:TEXT,fontSize:13,outline:"none",width:"100%",fontFamily:"inherit"}}
        onFocus={()=>setFoc(true)} onBlur={()=>setFoc(false)}
      />
    </div>
  );
}

function Sel({label, value, onChange, opts}) {
  const [foc,setFoc]=useState(false);
  return (
    <div style={{display:"flex",flexDirection:"column",gap:5}}>
      {label && <label style={{fontSize:11,color:MUT,textTransform:"uppercase",letterSpacing:"0.09em",fontWeight:500}}>{label}</label>}
      <select value={value} onChange={onChange}
        style={{background:"#0d0d0d",border:`1px solid ${foc?GOLD:BRD2}`,borderRadius:8,padding:"9px 12px",color:TEXT,fontSize:13,outline:"none",width:"100%",fontFamily:"inherit",appearance:"none"}}
        onFocus={()=>setFoc(true)} onBlur={()=>setFoc(false)}>
        {opts.map(o=><option key={o} style={{background:"#0d0d0d"}}>{o}</option>)}
      </select>
    </div>
  );
}

function Txta({label, value, onChange, placeholder, rows=3}) {
  const [foc,setFoc]=useState(false);
  return (
    <div style={{display:"flex",flexDirection:"column",gap:5}}>
      {label && <label style={{fontSize:11,color:MUT,textTransform:"uppercase",letterSpacing:"0.09em",fontWeight:500}}>{label}</label>}
      <textarea value={value} onChange={onChange} placeholder={placeholder} rows={rows}
        style={{background:"#0d0d0d",border:`1px solid ${foc?GOLD:BRD2}`,borderRadius:8,padding:"9px 12px",color:TEXT,fontSize:13,outline:"none",width:"100%",fontFamily:"inherit",resize:"vertical",lineHeight:1.5}}
        onFocus={()=>setFoc(true)} onBlur={()=>setFoc(false)}/>
    </div>
  );
}

function Tag({val,active,onClick}) {
  return (
    <button onClick={onClick} style={{padding:"5px 12px",borderRadius:20,fontSize:12,cursor:"pointer",border:`1px solid ${active?GOLD:BRD2}`,background:active?`${GOLD}22`:"transparent",color:active?GOLD2:MUT,fontFamily:"inherit",transition:"all .15s",fontWeight:active?600:400}}>
      {val}
    </button>
  );
}

function Btn({children,onClick,disabled,variant="primary",small}) {
  const styles = {
    primary:{background:disabled?"#1a1a1a":GOLD,color:disabled?MUT:"#000",border:"none"},
    ghost:{background:"transparent",color:MUT,border:`1px solid ${BRD2}`},
    danger:{background:"transparent",color:"#ef4444",border:"1px solid #3f1a1a"},
  };
  return (
    <button onClick={onClick} disabled={disabled} style={{...styles[variant],borderRadius:8,padding:small?"7px 14px":"10px 22px",fontSize:small?12:13,fontWeight:600,cursor:disabled?"default":"pointer",fontFamily:"inherit",opacity:disabled?0.5:1,transition:"all .15s"}}>
      {children}
    </button>
  );
}

function StatCard({label,value,color,sub}) {
  return (
    <div style={{background:CARD,border:`1px solid ${BRD2}`,borderRadius:12,padding:"18px 20px"}}>
      <div style={{fontSize:11,color:MUT,textTransform:"uppercase",letterSpacing:"0.09em",marginBottom:8}}>{label}</div>
      <div style={{fontSize:26,fontWeight:700,color:color||TEXT,letterSpacing:"-0.02em",lineHeight:1}}>{value}</div>
      {sub && <div style={{fontSize:12,color:MUT,marginTop:5}}>{sub}</div>}
    </div>
  );
}

function Card({children, style}) {
  return <div style={{background:CARD,border:`1px solid ${BRD2}`,borderRadius:12,padding:"20px 22px",...style}}>{children}</div>;
}

function SectionTitle({children}) {
  return <div style={{fontSize:14,fontWeight:700,color:TEXT,marginBottom:16,letterSpacing:"-0.01em"}}>{children}</div>;
}

// ── Main App ────────────────────────────────────────────────────────────────
export default function App() {
  const [trades, setTrades] = useState([]);
  const [rules, setRules] = useState(DEF_RULES);
  const [maxTrades, setMaxTrades] = useState(2);
  const [maxLoss, setMaxLoss] = useState(200);
  const [view, setView] = useState("dashboard");
  const [form, setForm] = useState(EMPTY_TRADE);
  const [editId, setEditId] = useState(null);
  const [selected, setSelected] = useState(null);
  const [aiResult, setAiResult] = useState(null);
  const [aiLoading, setAiLoading] = useState(false);
  const [filter, setFilter] = useState("");
  const [newRule, setNewRule] = useState("");
  const F = patch => setForm(p=>({...p,...patch}));

  // Load persisted data
  useEffect(()=>{
    const d = loadData();
      if(d) {
        if(d.trades) setTrades(d.trades);
        if(d.rules) setRules(d.rules);
        if(d.maxTrades) setMaxTrades(d.maxTrades);
        if(d.maxLoss) setMaxLoss(d.maxLoss);
      }
  },[]);

  // Save on change
  useEffect(()=>{
    saveData({trades,rules,maxTrades,maxLoss});
  },[trades,rules,maxTrades,maxLoss]);

  // ── Computed stats ──────────────────────────────────────────────────────
  const pnls = trades.map(t=>parseFloat(t.pnlMoney)||0);
  const totalPnl = pnls.reduce((a,b)=>a+b,0);
  const winTrades = trades.filter(t=>parseFloat(t.pnlMoney)>0);
  const lossTrades = trades.filter(t=>parseFloat(t.pnlMoney)<0);
  const winRate = trades.length ? ((winTrades.length/trades.length)*100).toFixed(1) : 0;
  const avgWin = winTrades.length ? (winTrades.reduce((a,t)=>a+(parseFloat(t.pnlMoney)||0),0)/winTrades.length) : 0;
  const avgLoss = lossTrades.length ? (lossTrades.reduce((a,t)=>a+(parseFloat(t.pnlMoney)||0),0)/lossTrades.length) : 0;
  const pf = Math.abs(avgLoss)>0 ? (avgWin/Math.abs(avgLoss)).toFixed(2) : "∞";
  const cumPnl = trades.slice(-30).reduce((acc,t,i)=>{acc.push((acc[i-1]||0)+(parseFloat(t.pnlMoney)||0));return acc;},[]);
  const today = new Date().toISOString().slice(0,10);
  const todayTrades = trades.filter(t=>t.date===today);
  const todayPnl = todayTrades.reduce((a,t)=>a+(parseFloat(t.pnlMoney)||0),0);
  const avgScore = trades.length ? Math.round(trades.reduce((a,t)=>a+(t.score||calcScore(t,rules)),0)/trades.length) : 0;

  const revIds = useMemo(()=>{
    const ids = new Set();
    const sorted = [...trades].sort((a,b)=>new Date(a.date+" "+(a.entryTime||"00:00"))-new Date(b.date+" "+(b.entryTime||"00:00")));
    sorted.forEach((t,i)=>{
      if(!i) return;
      const prev = sorted[i-1];
      if(prev.date===t.date && parseFloat(prev.pnlMoney)<0) {
        if(t.mistakeTags?.includes("Revenge Trade")||t.mistakeTags?.includes("Tilt")) ids.add(t.id);
      }
    });
    return ids;
  },[trades]);

  const setupStats = useMemo(()=>{
    const m={};
    trades.forEach(t=>{
      if(!t.setup) return;
      if(!m[t.setup]) m[t.setup]={n:0,w:0,pnl:0};
      m[t.setup].n++;
      if(parseFloat(t.pnlMoney)>0) m[t.setup].w++;
      m[t.setup].pnl += parseFloat(t.pnlMoney)||0;
    });
    return Object.entries(m).sort((a,b)=>b[1].pnl-a[1].pnl);
  },[trades]);

  const brokenTrades = trades.filter(t=>t.matchedPlan==="Broke Plan");
  const brokenCost = brokenTrades.reduce((a,t)=>a+(parseFloat(t.pnlMoney)||0),0);

  // ── Warnings ──────────────────────────────────────────────────────────────
  const warnings = [];
  const recentLosses = [...trades].reverse().slice(0,5).filter(t=>parseFloat(t.pnlMoney)<0);
  if(recentLosses.length>=2) warnings.push({type:"red",msg:"2+ consecutive losses — consider stopping."});
  if(todayTrades.length>=maxTrades) warnings.push({type:"amber",msg:`Daily trade limit of ${maxTrades} reached.`});
  if(todayPnl<=-maxLoss) warnings.push({type:"red",msg:`Daily loss limit of $${maxLoss} hit. Stop trading.`});

  // ── Save trade ─────────────────────────────────────────────────────────────
  function saveTrade() {
    if(!form.asset) return;
    const sc = calcScore(form, rules);
    const entry = {...form, score:sc};
    if(editId) {
      setTrades(p=>p.map(t=>t.id===editId?{...entry,id:editId}:t));
      setEditId(null);
    } else {
      setTrades(p=>[...p,{...entry,id:Date.now().toString()}]);
    }
    setForm(EMPTY_TRADE);
    setView("journal");
  }

  // ── AI analysis ─────────────────────────────────────────────────────────
  async function runAI(trade) {
    setAiLoading(true); setAiResult(null);
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages",{
        method:"POST", headers:{"Content-Type":"application/json"},
        body:JSON.stringify({
          model:"claude-sonnet-4-20250514", max_tokens:800,
          messages:[{role:"user",content:`You are the head coach at Legacy Exchange Academy. Analyze this trade briefly.
${trade.asset} ${trade.direction} | Setup:${trade.setup} | R:${trade.actualR} | PnL:$${trade.pnlMoney}
Plan:${trade.matchedPlan} | EmoPre:${trade.emotionBefore} | Score:${trade.score||calcScore(trade,rules)}/100
Mistakes:${trade.mistakeTags?.join(",")||"None"} | Why:${trade.whyTrade||"Not provided"}
Return ONLY valid JSON no markdown: {"grade":"A/B/C/D/F","strengths":["..."],"fixes":["..."],"coachNote":"2 sentences","next":"one action"}`}]
        })
      });
      const d = await res.json();
      const txt = d.content?.map(b=>b.text||"").join("")||"";
      setAiResult(JSON.parse(txt.replace(/```json|```/g,"").trim()));
    } catch { setAiResult({error:true}); }
    setAiLoading(false);
  }

  async function runPortfolioAI() {
    if(trades.length<3) return;
    setAiLoading(true); setAiResult(null);
    try {
      const topMistakes = MISTAKES.map(m=>({m,n:trades.filter(t=>t.mistakeTags?.includes(m)).length})).filter(x=>x.n>0).sort((a,b)=>b.n-a.n).slice(0,4);
      const res = await fetch("https://api.anthropic.com/v1/messages",{
        method:"POST", headers:{"Content-Type":"application/json"},
        body:JSON.stringify({
          model:"claude-sonnet-4-20250514", max_tokens:1000,
          messages:[{role:"user",content:`You are the head coach at Legacy Exchange Academy. Honest behavioral analysis.
${trades.length} trades | WR:${winRate}% | PnL:$${totalPnl.toFixed(0)} | PF:${pf}
AvgWin:$${avgWin.toFixed(0)} | AvgLoss:$${avgLoss.toFixed(0)} | AvgScore:${avgScore}/100
BrokenPlan:${brokenTrades.length} costing $${brokenCost.toFixed(0)} | Revenge:${revIds.size}
TopMistakes:${topMistakes.map(x=>`${x.m}(${x.n})`).join(",")}
Setups:${setupStats.slice(0,4).map(([s,v])=>`${s}:${v.n}t/${(v.w/v.n*100).toFixed(0)}%WR`).join(",")}
Return ONLY valid JSON no markdown: {"headline":"...","leak":"biggest behavioral leak","edge":"what works","plan":["action1","action2","action3"],"challenge":"week challenge","closing":"2 sentences"}`}]
        })
      });
      const d = await res.json();
      const txt = d.content?.map(b=>b.text||"").join("")||"";
      setAiResult({portfolio:true,...JSON.parse(txt.replace(/```json|```/g,"").trim())});
    } catch { setAiResult({error:true}); }
    setAiLoading(false);
  }

  // ── Tag toggle ─────────────────────────────────────────────────────────
  function toggleTag(key, val) {
    const cur = form[key]||[];
    F({[key]: cur.includes(val) ? cur.filter(x=>x!==val) : [...cur,val]});
  }

  const filtered = trades
    .filter(t=>!filter||(t.asset+t.setup+(t.mistakeTags||[]).join("")).toLowerCase().includes(filter.toLowerCase()))
    .sort((a,b)=>new Date(b.date)-new Date(a.date));

  // ── Nav ────────────────────────────────────────────────────────────────
  const NAV_ITEMS = [
    {id:"dashboard",label:"Dashboard"},
    {id:"journal",label:"Journal"},
    {id:"log",label:"Log Trade"},
    {id:"review",label:"Analytics"},
    {id:"rules",label:"Rules"},
    {id:"insights",label:"AI Coach"},
  ];

  const gotoLog = () => { setEditId(null); setForm(EMPTY_TRADE); setView("log"); };

  // ─────────────────────────────────────────────────────────────────────────
  return (
    <div style={{background:BG,minHeight:"100vh",color:TEXT,fontFamily:"Inter,system-ui,sans-serif",display:"flex",flexDirection:"column"}}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        *{box-sizing:border-box;margin:0;padding:0}
        ::-webkit-scrollbar{width:4px;height:4px}
        ::-webkit-scrollbar-thumb{background:#2a2a2a;border-radius:4px}
        input::placeholder,textarea::placeholder{color:#3A3428}
        select option{background:#0d0d0d}
        input[type=checkbox]{accent-color:${GOLD};cursor:pointer}
        input[type=range]{accent-color:${GOLD};width:100%}
        .tr:hover{background:#161616!important;cursor:pointer}
        .fade{animation:fi .18s ease}
        @keyframes fi{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
        @keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
      `}</style>

      {/* Ticker */}
      <div style={{background:GOLD,height:26,overflow:"hidden",display:"flex",alignItems:"center",flexShrink:0}}>
        <div style={{display:"inline-block",animation:"ticker 30s linear infinite",whiteSpace:"nowrap",fontSize:11,color:"#000",fontWeight:700,letterSpacing:"0.04em"}}>
          {[1,2].map(i=><span key={i}>&nbsp;&nbsp;EUR/USD &nbsp;•&nbsp; GBP/USD &nbsp;•&nbsp; XAU/USD &nbsp;•&nbsp; NAS100 &nbsp;•&nbsp; SPX500 &nbsp;•&nbsp; US30 &nbsp;•&nbsp; GBP/JPY &nbsp;•&nbsp; USD/JPY &nbsp;•&nbsp; BTC/USD &nbsp;•&nbsp; ETH/USD &nbsp;•&nbsp; SILVER &nbsp;•&nbsp; OIL &nbsp;•&nbsp;</span>)}
        </div>
      </div>

      {/* Header */}
      <div style={{background:"#0C0C0C",borderBottom:`1px solid ${BRD}`,padding:"0 24px",display:"flex",alignItems:"center",justifyContent:"space-between",height:56,flexShrink:0}}>
        <div style={{display:"flex",alignItems:"center",gap:12}}>
          <div style={{fontFamily:"Georgia,serif",fontSize:16,fontWeight:700,color:GOLD,letterSpacing:"0.04em"}}>LEGACY EXCHANGE</div>
          <div style={{width:1,height:20,background:BRD2}}/>
          <div style={{fontSize:12,color:MUT,letterSpacing:"0.1em",textTransform:"uppercase"}}>Trade Journal</div>
        </div>
        <nav style={{display:"flex",gap:2}}>
          {NAV_ITEMS.map(n=>(
            <button key={n.id} onClick={()=>{ if(n.id!=="log"){setView(n.id);setEditId(null);setForm(EMPTY_TRADE);setAiResult(null);}else gotoLog(); }}
              style={{background:"none",border:"none",padding:"8px 14px",fontSize:12,fontWeight:500,color:view===n.id?GOLD:MUT,cursor:"pointer",fontFamily:"inherit",borderBottom:`2px solid ${view===n.id?GOLD:"transparent"}`,transition:"all .15s",letterSpacing:"0.02em"}}>
              {n.label}
            </button>
          ))}
        </nav>
        <div style={{display:"flex",gap:8,alignItems:"center"}}>
          {warnings.map((w,i)=>(
            <div key={i} style={{background:w.type==="red"?"#1f0a0a":"#1a1200",border:`1px solid ${w.type==="red"?"#5a1a1a":"#4a3000"}`,borderRadius:6,padding:"4px 10px",fontSize:11,color:w.type==="red"?"#ef4444":"#f59e0b",fontWeight:500}}>
              {w.msg}
            </div>
          ))}
          <Btn small onClick={gotoLog}>+ Log Trade</Btn>
        </div>
      </div>

      {/* Page */}
      <div style={{padding:"24px",flex:1}} className="fade" key={view}>

        {/* ── DASHBOARD ─────────────────────────────────────────────────── */}
        {view==="dashboard" && (
          <div style={{display:"flex",flexDirection:"column",gap:16}}>
            <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12}}>
              <StatCard label="Total P&L" value={fmtPnl(totalPnl)} color={pnlClr(totalPnl)}/>
              <StatCard label="Win Rate" value={winRate+"%"} color={parseFloat(winRate)>=50?"#22c55e":"#ef4444"} sub={`${winTrades.length}W · ${lossTrades.length}L`}/>
              <StatCard label="Profit Factor" value={pf} color={parseFloat(pf)>=1.5?"#22c55e":"#ef4444"} sub={`${trades.length} trades total`}/>
              <StatCard label="Avg Discipline" value={avgScore+"/100"} color={scoreGrade(avgScore).color} sub={scoreGrade(avgScore).label}/>
            </div>

            <div style={{display:"grid",gridTemplateColumns:"2fr 1fr",gap:12}}>
              <Card>
                <SectionTitle>Equity Curve</SectionTitle>
                <Spark data={cumPnl} w={480} h={60}/>
              </Card>
              <Card>
                <SectionTitle>Today · {today}</SectionTitle>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:12}}>
                  <div>
                    <div style={{fontSize:11,color:MUT,marginBottom:4}}>P&L</div>
                    <div style={{fontSize:20,fontWeight:700,color:pnlClr(todayPnl)}}>{fmtPnl(todayPnl)}</div>
                  </div>
                  <div>
                    <div style={{fontSize:11,color:MUT,marginBottom:4}}>Trades</div>
                    <div style={{fontSize:20,fontWeight:700,color:GOLD}}>{todayTrades.length}/{maxTrades}</div>
                  </div>
                </div>
                <div style={{height:4,background:"#1a1a1a",borderRadius:2,overflow:"hidden"}}>
                  <div style={{height:"100%",width:`${clamp(todayTrades.length/maxTrades*100,0,100)}%`,background:todayTrades.length>=maxTrades?"#ef4444":GOLD,borderRadius:2,transition:"width .3s"}}/>
                </div>
              </Card>
            </div>

            <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:12}}>
              <Card>
                <div style={{fontSize:11,color:MUT,marginBottom:6,textTransform:"uppercase",letterSpacing:"0.08em"}}>Avg Win / Loss</div>
                <div style={{fontSize:20,fontWeight:700,color:"#22c55e"}}>{fmtPnl(avgWin)}</div>
                <div style={{fontSize:20,fontWeight:700,color:"#ef4444",marginTop:4}}>{fmtPnl(avgLoss)}</div>
              </Card>
              <Card style={{borderColor:revIds.size>0?"#3f1a1a":BRD2}}>
                <div style={{fontSize:11,color:MUT,marginBottom:6,textTransform:"uppercase",letterSpacing:"0.08em"}}>Revenge Flags</div>
                <div style={{fontSize:28,fontWeight:700,color:revIds.size>0?"#ef4444":MUT}}>{revIds.size}</div>
                <div style={{fontSize:11,color:MUT,marginTop:4}}>Broken plan cost: <span style={{color:"#ef4444"}}>{fmtPnl(brokenCost)}</span></div>
              </Card>
              <Card>
                <div style={{fontSize:11,color:MUT,marginBottom:6,textTransform:"uppercase",letterSpacing:"0.08em"}}>Best Setup</div>
                <div style={{fontSize:16,fontWeight:600,color:TEXT}}>{setupStats[0]?setupStats[0][0]:"—"}</div>
                <div style={{fontSize:11,color:MUT,marginTop:4}}>{setupStats[0]?`${setupStats[0][1].n} trades · ${(setupStats[0][1].w/setupStats[0][1].n*100).toFixed(0)}% WR`:"Log trades with setups"}</div>
              </Card>
            </div>

            {/* Recent trades */}
            <Card>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:14}}>
                <SectionTitle>Recent Trades</SectionTitle>
                <button onClick={()=>setView("journal")} style={{fontSize:12,color:GOLD,background:"none",border:"none",cursor:"pointer",fontFamily:"inherit"}}>View all →</button>
              </div>
              {trades.length===0 ? (
                <div style={{textAlign:"center",padding:"36px 0",color:MUT}}>
                  <div style={{fontSize:32,marginBottom:10,opacity:0.2}}>◦</div>
                  <div style={{fontSize:14,marginBottom:14}}>No trades logged yet</div>
                  <Btn small onClick={gotoLog}>Log your first trade</Btn>
                </div>
              ) : (
                <div>
                  <div style={{display:"grid",gridTemplateColumns:"90px 44px 76px 1fr 72px 60px 72px 80px",gap:0,padding:"8px 12px",borderBottom:`1px solid ${BRD}`,fontSize:10,color:MUT,textTransform:"uppercase",letterSpacing:"0.08em"}}>
                    <span>Date</span><span>Dir</span><span>Asset</span><span>Setup</span><span>Session</span><span>R</span><span>Score</span><span style={{textAlign:"right"}}>P&L</span>
                  </div>
                  {[...trades].reverse().slice(0,6).map(t=>{
                    const sc=t.score||calcScore(t,rules);
                    const isR=revIds.has(t.id);
                    return (
                      <div key={t.id} className="tr" onClick={()=>{setSelected(t);setAiResult(null);}}
                        style={{display:"grid",gridTemplateColumns:"90px 44px 76px 1fr 72px 60px 72px 80px",gap:0,padding:"11px 12px",borderBottom:`1px solid ${BRD}`,fontSize:12,alignItems:"center",borderLeft:`3px solid ${isR?"#ef4444":"transparent"}`}}>
                        <span style={{color:MUT,fontSize:11}}>{t.date}</span>
                        <span style={{display:"inline-flex",padding:"2px 7px",borderRadius:20,fontSize:10,fontWeight:600,background:t.direction==="Long"?"#0a1f0a":"#1f0a0a",color:t.direction==="Long"?"#22c55e":"#ef4444"}}>{t.direction[0]}</span>
                        <span style={{fontWeight:600,fontSize:13}}>{t.asset}</span>
                        <span style={{color:MUT}}>{t.setup||"—"}</span>
                        <span style={{color:MUT,fontSize:11}}>{t.session}</span>
                        <span style={{color:pnlClr(t.actualR)}}>{fmtR(t.actualR)}</span>
                        <span style={{color:scoreGrade(sc).color,fontSize:11}}>{sc}</span>
                        <span style={{textAlign:"right",fontWeight:700,color:pnlClr(t.pnlMoney)}}>{fmtPnl(t.pnlMoney)}</span>
                      </div>
                    );
                  })}
                </div>
              )}
            </Card>
          </div>
        )}

        {/* ── JOURNAL ──────────────────────────────────────────────────────── */}
        {view==="journal" && (
          <div>
            <div style={{display:"flex",gap:10,marginBottom:16,alignItems:"center"}}>
              <input value={filter} onChange={e=>setFilter(e.target.value)} placeholder="Filter by asset, setup, mistakes..."
                style={{flex:1,background:"#0d0d0d",border:`1px solid ${BRD2}`,borderRadius:8,padding:"9px 14px",color:TEXT,fontSize:13,outline:"none",fontFamily:"inherit"}}/>
              <div style={{fontSize:12,color:MUT}}>{filtered.length} trades</div>
              <Btn small onClick={gotoLog}>+ New Trade</Btn>
            </div>
            <Card style={{padding:0,overflow:"hidden"}}>
              <div style={{display:"grid",gridTemplateColumns:"90px 44px 76px 1fr 68px 60px 72px 72px 80px",gap:0,padding:"10px 16px",borderBottom:`1px solid ${BRD}`,fontSize:10,color:MUT,textTransform:"uppercase",letterSpacing:"0.08em"}}>
                <span>Date</span><span>Dir</span><span>Asset</span><span>Setup</span><span>Emotion</span><span>Plan</span><span>Session</span><span>Score</span><span style={{textAlign:"right"}}>P&L</span>
              </div>
              {filtered.length===0 ? (
                <div style={{padding:"40px",textAlign:"center",color:MUT,fontSize:13}}>{trades.length===0?"No trades yet":"No matches"}</div>
              ) : filtered.map(t=>{
                const sc=t.score||calcScore(t,rules);
                const isR=revIds.has(t.id);
                const planC = t.matchedPlan==="Matched Plan"?"#22c55e":t.matchedPlan==="Broke Plan"?"#ef4444":"#f59e0b";
                const planB = t.matchedPlan==="Matched Plan"?"#0a1f0a":t.matchedPlan==="Broke Plan"?"#1f0a0a":"#1a1200";
                return (
                  <div key={t.id} className="tr" onClick={()=>{setSelected(t);setAiResult(null);}}
                    style={{display:"grid",gridTemplateColumns:"90px 44px 76px 1fr 68px 60px 72px 72px 80px",gap:0,padding:"11px 16px",borderBottom:`1px solid ${BRD}`,fontSize:12,alignItems:"center",borderLeft:`3px solid ${isR?"#ef4444":"transparent"}`}}>
                    <span style={{color:MUT,fontSize:11}}>{t.date}</span>
                    <span style={{display:"inline-flex",padding:"2px 7px",borderRadius:20,fontSize:10,fontWeight:600,background:t.direction==="Long"?"#0a1f0a":"#1f0a0a",color:t.direction==="Long"?"#22c55e":"#ef4444"}}>{t.direction[0]}</span>
                    <span style={{fontWeight:600,fontSize:13}}>{t.asset}</span>
                    <span style={{color:MUT}}>{t.setup||"—"}</span>
                    <span style={{color:MUT,fontSize:11}}>{t.emotionBefore}</span>
                    <span style={{display:"inline-flex",padding:"2px 6px",borderRadius:20,fontSize:10,fontWeight:600,background:planB,color:planC}}>{t.matchedPlan==="Matched Plan"?"✓":t.matchedPlan==="Broke Plan"?"✗":"~"}</span>
                    <span style={{color:MUT,fontSize:11}}>{t.session}</span>
                    <span style={{color:scoreGrade(sc).color,fontSize:11}}>{sc}</span>
                    <span style={{textAlign:"right",fontWeight:700,color:pnlClr(t.pnlMoney)}}>{fmtPnl(t.pnlMoney)}</span>
                  </div>
                );
              })}
            </Card>
          </div>
        )}

        {/* ── LOG TRADE ────────────────────────────────────────────────────── */}
        {view==="log" && (
          <div style={{maxWidth:820,display:"flex",flexDirection:"column",gap:14}}>
            <Card>
              <SectionTitle>Trade Info</SectionTitle>
              <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12,marginBottom:12}}>
                <Inp label="Date" type="date" value={form.date} onChange={e=>F({date:e.target.value})}/>
                <Inp label="Asset" value={form.asset} onChange={e=>F({asset:e.target.value.toUpperCase()})} placeholder="EUR/USD"/>
                <Sel label="Direction" value={form.direction} onChange={e=>F({direction:e.target.value})} opts={["Long","Short"]}/>
                <Sel label="Session" value={form.session} onChange={e=>F({session:e.target.value})} opts={SESSIONS}/>
              </div>
              <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12}}>
                <Sel label="Setup" value={form.setup} onChange={e=>F({setup:e.target.value})} opts={["Select...", ...SETUPS]}/>
                <Sel label="Timeframe" value={form.timeframe} onChange={e=>F({timeframe:e.target.value})} opts={TIMEFRAMES}/>
                <Sel label="Plan Match" value={form.matchedPlan} onChange={e=>F({matchedPlan:e.target.value})} opts={["Matched Plan","Partial Plan","Broke Plan"]}/>
                <Sel label="Emotion Before" value={form.emotionBefore} onChange={e=>F({emotionBefore:e.target.value})} opts={EMO}/>
              </div>
            </Card>

            <Card>
              <SectionTitle>Execution</SectionTitle>
              <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12,marginBottom:12}}>
                <Inp label="Entry Price" type="number" step="any" value={form.entry} onChange={e=>F({entry:e.target.value})} placeholder="0.00000"/>
                <Inp label="Stop Loss" type="number" step="any" value={form.stopLoss} onChange={e=>F({stopLoss:e.target.value})} placeholder="0.00000"/>
                <Inp label="Take Profit" type="number" step="any" value={form.takeProfit} onChange={e=>F({takeProfit:e.target.value})} placeholder="0.00000"/>
                <Inp label="Risk %" type="number" step="0.1" value={form.riskPct} onChange={e=>F({riskPct:e.target.value})} placeholder="1.0"/>
              </div>
              <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12}}>
                <Inp label="Actual R" type="number" step="any" value={form.actualR} onChange={e=>F({actualR:e.target.value})} placeholder="e.g. 2.5"/>
                <Inp label="P&L ($)" type="number" step="any" value={form.pnlMoney} onChange={e=>F({pnlMoney:e.target.value})} placeholder="+/-"/>
                <Inp label="Entry Time" type="time" value={form.entryTime} onChange={e=>F({entryTime:e.target.value})}/>
                <Inp label="Exit Time" type="time" value={form.exitTime} onChange={e=>F({exitTime:e.target.value})}/>
              </div>
            </Card>

            <Card>
              <SectionTitle>Rules Checklist</SectionTitle>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
                {rules.filter(r=>r.on).map(r=>(
                  <label key={r.id} style={{display:"flex",alignItems:"center",gap:9,cursor:"pointer",padding:"8px 10px",borderRadius:8,background:(form.rulesFollowed||[]).includes(r.id)?`${GOLD}15`:"transparent",border:`1px solid ${(form.rulesFollowed||[]).includes(r.id)?BRD2:"transparent"}`}}>
                    <input type="checkbox" checked={(form.rulesFollowed||[]).includes(r.id)} onChange={e=>{ const c=form.rulesFollowed||[]; F({rulesFollowed:e.target.checked?[...c,r.id]:c.filter(x=>x!==r.id)}); }}/>
                    <span style={{fontSize:12,color:TEXT}}>{r.text}</span>
                    <span style={{fontSize:10,color:r.sev==="hard"?"#ef4444":"#f59e0b",marginLeft:"auto"}}>{r.sev}</span>
                  </label>
                ))}
              </div>
            </Card>

            <Card>
              <SectionTitle>Psychology & Mistakes</SectionTitle>
              <div style={{marginBottom:12}}>
                <div style={{fontSize:11,color:MUT,textTransform:"uppercase",letterSpacing:"0.08em",marginBottom:8}}>Mistake Tags</div>
                <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
                  {MISTAKES.map(m=><Tag key={m} val={m} active={(form.mistakeTags||[]).includes(m)} onClick={()=>toggleTag("mistakeTags",m)}/>)}
                </div>
              </div>
              <div>
                <div style={{fontSize:11,color:MUT,textTransform:"uppercase",letterSpacing:"0.08em",marginBottom:8}}>Lesson Tags</div>
                <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
                  {LESSONS.map(l=><Tag key={l} val={l} active={(form.lessonTags||[]).includes(l)} onClick={()=>toggleTag("lessonTags",l)}/>)}
                </div>
              </div>
            </Card>

            <Card>
              <SectionTitle>Journal Notes</SectionTitle>
              <Txta label="Why did you take this trade?" value={form.whyTrade} onChange={e=>F({whyTrade:e.target.value})} placeholder="Setup rationale, market structure, entry trigger..." rows={3}/>
              <div style={{marginTop:12}}>
                <Txta label="Post-trade notes & lesson learned" value={form.notes} onChange={e=>F({notes:e.target.value})} placeholder="What happened? What would you do differently?" rows={2}/>
              </div>
            </Card>

            <div style={{display:"flex",gap:10,justifyContent:"flex-end"}}>
              <Btn variant="ghost" small onClick={()=>{setView("journal");setEditId(null);setForm(EMPTY_TRADE);}}>Cancel</Btn>
              <Btn small onClick={saveTrade} disabled={!form.asset}>{editId?"Save Changes":"Log Trade"}</Btn>
            </div>
          </div>
        )}

        {/* ── ANALYTICS ────────────────────────────────────────────────────── */}
        {view==="review" && (
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12}}>
              <StatCard label="Total Trades" value={trades.length} color={GOLD}/>
              <StatCard label="Avg Win" value={fmtPnl(avgWin)} color="#22c55e"/>
              <StatCard label="Avg Loss" value={fmtPnl(avgLoss)} color="#ef4444"/>
              <StatCard label="Broken Plan Cost" value={fmtPnl(brokenCost)} color="#ef4444" sub={`${brokenTrades.length} broken trades`}/>
            </div>

            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:14}}>
              <Card>
                <SectionTitle>Performance by Setup</SectionTitle>
                {setupStats.length===0 ? <div style={{color:MUT,fontSize:12}}>No setup data yet</div> : setupStats.map(([s,v])=>(
                  <div key={s} style={{marginBottom:14}}>
                    <div style={{display:"flex",justifyContent:"space-between",marginBottom:5}}>
                      <span style={{fontSize:13,fontWeight:500}}>{s}</span>
                      <div style={{display:"flex",gap:10,fontSize:12,color:MUT}}>
                        <span>{v.n}t · {v.n?(v.w/v.n*100).toFixed(0):0}%WR</span>
                        <span style={{color:pnlClr(v.pnl),fontWeight:600}}>{fmtPnl(v.pnl)}</span>
                      </div>
                    </div>
                    <div style={{height:4,background:"#1a1a1a",borderRadius:2,overflow:"hidden"}}>
                      <div style={{height:"100%",width:`${v.n?(v.w/v.n*100):0}%`,background:v.pnl>=0?"linear-gradient(90deg,#D4A843,#F0C060)":"#ef4444",borderRadius:2}}/>
                    </div>
                  </div>
                ))}
              </Card>

              <Card>
                <SectionTitle>Mistake Frequency</SectionTitle>
                {MISTAKES.map(m=>{
                  const mt=trades.filter(t=>(t.mistakeTags||[]).includes(m));
                  if(!mt.length) return null;
                  const mp=mt.reduce((a,t)=>a+(parseFloat(t.pnlMoney)||0),0);
                  return (
                    <div key={m} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"7px 0",borderBottom:`1px solid ${BRD}`,fontSize:12}}>
                      <span style={{color:TEXT}}>{m}</span>
                      <div style={{display:"flex",gap:10,color:MUT}}>
                        <span>{mt.length}×</span>
                        <span style={{color:pnlClr(mp),fontWeight:600,minWidth:64,textAlign:"right"}}>{fmtPnl(mp)}</span>
                      </div>
                    </div>
                  );
                }).filter(Boolean)}
              </Card>
            </div>
          </div>
        )}

        {/* ── RULES ────────────────────────────────────────────────────────── */}
        {view==="rules" && (
          <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:14}}>
            <Card>
              <SectionTitle>Trading Rules</SectionTitle>
              <div style={{display:"flex",flexDirection:"column",gap:8,marginBottom:14}}>
                {rules.map((r,i)=>{
                  const fc=trades.filter(t=>(t.rulesFollowed||[]).includes(r.id)).length;
                  const tc=trades.filter(t=>t.rulesFollowed).length;
                  const c=tc>0?Math.round(fc/tc*100):null;
                  return (
                    <div key={r.id} style={{display:"flex",alignItems:"center",gap:10,background:"#0d0d0d",border:`1px solid ${BRD}`,borderRadius:8,padding:"10px 14px"}}>
                      <input type="checkbox" checked={r.on} onChange={e=>setRules(rules.map((x,j)=>j===i?{...x,on:e.target.checked}:x))}/>
                      <span style={{flex:1,fontSize:12,color:r.on?TEXT:MUT}}>{r.text}</span>
                      <span style={{fontSize:10,padding:"2px 6px",borderRadius:20,background:r.sev==="hard"?"#1f0a0a":"#1a1200",color:r.sev==="hard"?"#ef4444":"#f59e0b"}}>{r.sev}</span>
                      {c!=null && <span style={{fontSize:11,color:c>=80?"#22c55e":c>=60?"#f59e0b":"#ef4444",minWidth:28,textAlign:"right"}}>{c}%</span>}
                      <button style={{background:"none",border:"none",color:"#3f1a1a",cursor:"pointer",fontSize:16}} onClick={()=>setRules(rules.filter((_,j)=>j!==i))}>×</button>
                    </div>
                  );
                })}
              </div>
              <div style={{display:"flex",gap:8}}>
                <input value={newRule} onChange={e=>setNewRule(e.target.value)} placeholder="Add a new rule..."
                  onKeyDown={e=>{ if(e.key==="Enter"&&newRule.trim()){ setRules([...rules,{id:`r${Date.now()}`,text:newRule.trim(),sev:"warn",on:true}]); setNewRule(""); }}}
                  style={{flex:1,background:"#0d0d0d",border:`1px solid ${BRD2}`,borderRadius:8,padding:"9px 12px",color:TEXT,fontSize:13,outline:"none",fontFamily:"inherit"}}/>
                <Btn small onClick={()=>{ if(newRule.trim()){ setRules([...rules,{id:`r${Date.now()}`,text:newRule.trim(),sev:"warn",on:true}]); setNewRule(""); }}}>Add</Btn>
              </div>
            </Card>

            <div style={{display:"flex",flexDirection:"column",gap:14}}>
              <Card>
                <SectionTitle>Risk Controls</SectionTitle>
                {[{l:"Daily Trade Limit",v:maxTrades,set:setMaxTrades,min:1,max:10,unit:` trades/day`},{l:"Daily Max Loss",v:maxLoss,set:setMaxLoss,min:50,max:2000,unit:` USD`}].map(({l,v,set,min,max,unit})=>(
                  <div key={l} style={{marginBottom:16}}>
                    <div style={{display:"flex",justifyContent:"space-between",marginBottom:6}}>
                      <span style={{fontSize:12,color:MUT,textTransform:"uppercase",letterSpacing:"0.08em"}}>{l}</span>
                      <span style={{fontSize:13,fontWeight:600,color:GOLD}}>{v}{unit}</span>
                    </div>
                    <input type="range" min={min} max={max} value={v} onChange={e=>set(parseInt(e.target.value))}/>
                  </div>
                ))}
              </Card>
              <Card>
                <SectionTitle>Discipline Score Breakdown</SectionTitle>
                {[["Plan Adherence","25pts"],["Stop Loss Set","15pts"],["Risk ≤ 2%","20pts"],["Quality Setup","10pts"],["No Emotional Tags","10pts"],["Rules Followed","10pts"],["Post-Trade Notes","10pts"]].map(([l,p])=>(
                  <div key={l} style={{display:"flex",justifyContent:"space-between",padding:"7px 0",borderBottom:`1px solid ${BRD}`,fontSize:12}}>
                    <span style={{color:MUT}}>{l}</span>
                    <span style={{color:GOLD,fontWeight:600}}>{p}</span>
                  </div>
                ))}
              </Card>
            </div>
          </div>
        )}

        {/* ── AI COACH ─────────────────────────────────────────────────────── */}
        {view==="insights" && (
          <div style={{maxWidth:800,display:"flex",flexDirection:"column",gap:14}}>
            <Card>
              <SectionTitle>Legacy Exchange AI Coach</SectionTitle>
              <div style={{fontSize:13,color:MUT,lineHeight:1.6,marginBottom:16}}>
                Get a comprehensive behavioral analysis of your trading journal — your specific leaks, psychological patterns, and a direct action plan to improve consistency.
              </div>
              <div style={{display:"flex",gap:10,alignItems:"center"}}>
                <Btn onClick={runPortfolioAI} disabled={trades.length<3||aiLoading}>{aiLoading?"Analyzing...":"Generate Full Report"}</Btn>
                {trades.length<3 && <span style={{fontSize:12,color:MUT}}>Requires 3+ trades</span>}
              </div>
            </Card>

            {aiLoading && <Card><div style={{textAlign:"center",padding:"32px",color:MUT,fontSize:12,letterSpacing:"0.12em"}}>ANALYZING YOUR TRADING PATTERNS...</div></Card>}
            {aiResult?.error && <Card style={{borderColor:"#5a1a1a"}}><div style={{color:"#ef4444",fontSize:13}}>Analysis failed. Please try again.</div></Card>}

            {aiResult?.portfolio && !aiLoading && (
              <div style={{display:"flex",flexDirection:"column",gap:12}} className="fade">
                <Card>
                  <div style={{fontSize:11,color:GOLD,textTransform:"uppercase",letterSpacing:"0.12em",marginBottom:8,fontWeight:600}}>Coach Assessment</div>
                  <div style={{fontSize:17,fontWeight:600,color:TEXT,lineHeight:1.4,marginBottom:16}}>{aiResult.headline}</div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:14}}>
                    <div style={{background:"#0a1f0a",border:"1px solid #1a3a1a",borderRadius:8,padding:"14px"}}>
                      <div style={{fontSize:11,color:"#22c55e",textTransform:"uppercase",letterSpacing:"0.1em",marginBottom:6}}>What's Working</div>
                      <div style={{fontSize:13,color:"#86efac",lineHeight:1.6}}>{aiResult.edge}</div>
                    </div>
                    <div style={{background:"#1f0a0a",border:"1px solid #3a1a1a",borderRadius:8,padding:"14px"}}>
                      <div style={{fontSize:11,color:"#ef4444",textTransform:"uppercase",letterSpacing:"0.1em",marginBottom:6}}>Biggest Leak</div>
                      <div style={{fontSize:13,color:"#fca5a5",lineHeight:1.6}}>{aiResult.leak}</div>
                    </div>
                  </div>
                  <div style={{marginBottom:14}}>
                    <div style={{fontSize:12,fontWeight:600,marginBottom:10,color:TEXT}}>Action Plan</div>
                    {(aiResult.plan||[]).map((a,i)=>(
                      <div key={i} style={{display:"flex",gap:12,padding:"9px 0",borderBottom:`1px solid ${BRD}`}}>
                        <span style={{width:22,height:22,borderRadius:6,background:`${GOLD}22`,color:GOLD,display:"flex",alignItems:"center",justifyContent:"center",fontSize:11,fontWeight:700,flexShrink:0}}>{i+1}</span>
                        <span style={{fontSize:13,color:TEXT,lineHeight:1.5}}>{a}</span>
                      </div>
                    ))}
                  </div>
                  {aiResult.challenge && (
                    <div style={{background:`${GOLD}15`,border:`1px solid ${GOLD}30`,borderRadius:8,padding:"14px",marginBottom:12}}>
                      <div style={{fontSize:11,color:GOLD,textTransform:"uppercase",letterSpacing:"0.1em",marginBottom:6,fontWeight:600}}>This Week's Challenge</div>
                      <div style={{fontSize:13,color:GOLD2,fontWeight:500}}>{aiResult.challenge}</div>
                    </div>
                  )}
                  <div style={{fontSize:13,color:MUT,lineHeight:1.7,fontStyle:"italic"}}>{aiResult.closing}</div>
                </Card>
              </div>
            )}

            <Card style={{padding:0,overflow:"hidden"}}>
              <div style={{padding:"14px 20px",borderBottom:`1px solid ${BRD}`,fontSize:13,fontWeight:600}}>Analyze a Specific Trade</div>
              {trades.length===0 ? (
                <div style={{padding:"24px",color:MUT,fontSize:12}}>Log some trades first</div>
              ) : [...trades].reverse().slice(0,6).map(t=>{
                const sc=t.score||calcScore(t,rules);
                return (
                  <div key={t.id} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"12px 20px",borderBottom:`1px solid ${BRD}`,fontSize:13}}>
                    <div style={{display:"flex",gap:10,alignItems:"center"}}>
                      <span style={{fontWeight:600}}>{t.asset}</span>
                      <span style={{color:MUT,fontSize:11}}>{t.date}</span>
                      <span style={{color:pnlClr(t.pnlMoney),fontWeight:600}}>{fmtPnl(t.pnlMoney)}</span>
                      <span style={{fontSize:11,color:scoreGrade(sc).color}}>Score:{sc}</span>
                    </div>
                    <Btn variant="ghost" small onClick={()=>{ setSelected(t); runAI(t); }}>Analyse →</Btn>
                  </div>
                );
              })}
            </Card>
          </div>
        )}
      </div>

      {/* ── TRADE DETAIL MODAL ───────────────────────────────────────────── */}
      {selected && (
        <div style={{position:"fixed",top:0,left:0,right:0,bottom:0,background:"rgba(0,0,0,0.88)",zIndex:9999,overflowY:"auto",padding:"40px 20px"}} onClick={()=>{setSelected(null);setAiResult(null);}}>
          <div style={{background:CARD,border:`1px solid ${BRD2}`,borderRadius:16,padding:28,maxWidth:660,margin:"0 auto",boxShadow:`0 24px 80px rgba(0,0,0,0.8)`}} className="fade" onClick={e=>e.stopPropagation()}>

            <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:18}}>
              <div>
                <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:4}}>
                  <span style={{display:"inline-flex",padding:"2px 10px",borderRadius:20,fontSize:11,fontWeight:600,background:selected.direction==="Long"?"#0a1f0a":"#1f0a0a",color:selected.direction==="Long"?"#22c55e":"#ef4444"}}>{selected.direction}</span>
                  <span style={{fontSize:22,fontWeight:800,letterSpacing:"-0.02em"}}>{selected.asset}</span>
                  <span style={{fontSize:12,color:MUT}}>{selected.setup} · {selected.timeframe}</span>
                  {revIds.has(selected.id) && <span style={{display:"inline-flex",padding:"2px 8px",borderRadius:20,fontSize:10,fontWeight:600,background:"#1f0a0a",color:"#ef4444"}}>REVENGE</span>}
                </div>
                <div style={{fontSize:12,color:MUT}}>{selected.date} · {selected.session} · {selected.matchedPlan}</div>
              </div>
              <button style={{background:"none",border:"none",color:MUT,cursor:"pointer",fontSize:22}} onClick={()=>{setSelected(null);setAiResult(null);}}>×</button>
            </div>

            <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:10,marginBottom:18}}>
              {[[fmtPnl(selected.pnlMoney),pnlClr(selected.pnlMoney),"P&L"],[fmtR(selected.actualR),pnlClr(selected.actualR),"R-Multiple"],[selected.riskPct?selected.riskPct+"%":"—",MUT,"Risk %"],[(selected.score||calcScore(selected,rules))+"/100",scoreGrade(selected.score||50).color,"Score"]].map(([v,c,l])=>(
                <div key={l} style={{background:"#0d0d0d",border:`1px solid ${BRD}`,borderRadius:8,padding:"11px 14px"}}>
                  <div style={{fontSize:10,color:MUT,textTransform:"uppercase",letterSpacing:"0.1em",marginBottom:4}}>{l}</div>
                  <div style={{fontSize:18,fontWeight:700,color:c}}>{v}</div>
                </div>
              ))}
            </div>

            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:14,fontSize:12}}>
              <div>
                {[["Entry",selected.entry],["Stop Loss",selected.stopLoss],["Take Profit",selected.takeProfit]].map(([l,v])=>(
                  <div key={l} style={{display:"flex",justifyContent:"space-between",padding:"5px 0",borderBottom:`1px solid ${BRD}`}}>
                    <span style={{color:MUT}}>{l}</span><span style={{color:TEXT}}>{v||"—"}</span>
                  </div>
                ))}
              </div>
              <div>
                {[["Emotion Before",selected.emotionBefore],["Emotion After",selected.emotionAfter],["Session",selected.session]].map(([l,v])=>(
                  <div key={l} style={{display:"flex",justifyContent:"space-between",padding:"5px 0",borderBottom:`1px solid ${BRD}`}}>
                    <span style={{color:MUT}}>{l}</span><span style={{color:TEXT}}>{v||"—"}</span>
                  </div>
                ))}
              </div>
            </div>

            {selected.whyTrade && (
              <div style={{background:"#0d0d0d",border:`1px solid ${BRD}`,borderRadius:8,padding:"12px",marginBottom:10}}>
                <div style={{fontSize:10,color:MUT,textTransform:"uppercase",letterSpacing:"0.1em",marginBottom:5}}>Pre-Trade Thesis</div>
                <div style={{fontSize:13,color:TEXT,lineHeight:1.5}}>{selected.whyTrade}</div>
              </div>
            )}
            {selected.notes && (
              <div style={{background:"#0d0d0d",border:`1px solid ${BRD}`,borderRadius:8,padding:"12px",marginBottom:14}}>
                <div style={{fontSize:10,color:MUT,textTransform:"uppercase",letterSpacing:"0.1em",marginBottom:5}}>Notes & Lessons</div>
                <div style={{fontSize:13,color:TEXT,lineHeight:1.5}}>{selected.notes}</div>
              </div>
            )}

            {((selected.mistakeTags||[]).length>0||(selected.lessonTags||[]).length>0) && (
              <div style={{marginBottom:14,display:"flex",flexWrap:"wrap",gap:6}}>
                {(selected.mistakeTags||[]).map(t=><span key={t} style={{padding:"3px 10px",borderRadius:20,fontSize:11,background:"#1f0a0a",color:"#ef4444"}}>{t}</span>)}
                {(selected.lessonTags||[]).map(t=><span key={t} style={{padding:"3px 10px",borderRadius:20,fontSize:11,background:"#0a1f0a",color:"#22c55e"}}>{t}</span>)}
              </div>
            )}

            {aiLoading && <div style={{textAlign:"center",padding:16,color:MUT,fontSize:12,letterSpacing:"0.1em"}}>COACH REVIEWING...</div>}

            {aiResult && !aiResult.portfolio && !aiResult.error && !aiLoading && (
              <div style={{background:`${GOLD}10`,border:`1px solid ${GOLD}25`,borderRadius:10,padding:16,marginBottom:14}} className="fade">
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:12}}>
                  <div style={{fontSize:11,color:GOLD,textTransform:"uppercase",letterSpacing:"0.12em",fontWeight:600}}>AI Coach Feedback</div>
                  <span style={{background:`${GOLD}22`,border:`1px solid ${GOLD}40`,padding:"3px 12px",borderRadius:6,fontSize:18,fontWeight:800,color:GOLD}}>{aiResult.grade}</span>
                </div>
                <div style={{fontSize:13,color:MUT,lineHeight:1.6,fontStyle:"italic",marginBottom:10}}>{aiResult.coachNote}</div>
                {aiResult.bias && <div style={{background:"#1a1000",border:"1px solid #3a2500",borderRadius:6,padding:"7px 10px",marginBottom:8,fontSize:12,color:"#f59e0b"}}>Bias: <strong>{aiResult.bias}</strong></div>}
                <div style={{marginBottom:6}}>{(aiResult.strengths||[]).map(s=><div key={s} style={{fontSize:12,color:"#86efac",marginBottom:2}}>✓ {s}</div>)}</div>
                <div style={{marginBottom:8}}>{(aiResult.fixes||[]).map(s=><div key={s} style={{fontSize:12,color:"#fca5a5",marginBottom:2}}>→ {s}</div>)}</div>
                {aiResult.next && <div style={{background:"#0d0d0d",border:`1px solid ${BRD}`,borderRadius:6,padding:"9px 12px",fontSize:12,color:TEXT}}><span style={{color:GOLD,fontWeight:600}}>Next trade: </span>{aiResult.next}</div>}
              </div>
            )}
            {aiResult?.error && <div style={{background:"#1f0a0a",border:"1px solid #5a1a1a",borderRadius:8,padding:12,color:"#ef4444",fontSize:12,marginBottom:12}}>Analysis failed.</div>}

            <div style={{display:"flex",justifyContent:"space-between",marginTop:6}}>
              <Btn variant="danger" small onClick={()=>{ setTrades(p=>p.filter(t=>t.id!==selected.id)); setSelected(null); setAiResult(null); }}>Delete</Btn>
              <div style={{display:"flex",gap:8}}>
                {!aiResult && !aiLoading && <Btn variant="ghost" small onClick={()=>runAI(selected)}>AI Analysis</Btn>}
                <Btn small onClick={()=>{ setForm(selected); setEditId(selected.id); setSelected(null); setAiResult(null); setView("log"); }}>Edit Trade</Btn>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
